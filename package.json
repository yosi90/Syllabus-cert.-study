{
  "name": "istqb-ctfl-v4-trainer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "validate": "npm run validate:data && npm test && npm run build && npm run test:e2e",
    "extract:data": "python scripts/extract_data.py",
    "extract:visuals": "python scripts/extract_visuals.py",
    "translate:data": "python scripts/translate_es.py",
    "validate:data": "tsx scripts/validate-data.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
